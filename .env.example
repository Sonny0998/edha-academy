# ============================================================
# EDHA Academy — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (required for certificate verify links)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Email — Resend (optional)
RESEND_API_KEY=re_your_key_here

# Payments — Stripe (optional)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_key

# Payments — MonCash (optional)
MONCASH_CLIENT_ID=your_client_id
MONCASH_CLIENT_SECRET=your_client_secret
MONCASH_MODE=sandbox

# Payments — PayPal (optional)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret
